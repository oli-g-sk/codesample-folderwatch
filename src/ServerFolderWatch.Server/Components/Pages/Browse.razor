@page "/browse"
@using ServerFolderWatch.Core.Model
@using ServerFolderWatch.Server.PageModels
@inject NavigationManager NavigationManager
@inject BrowsePageModel Model;

<div id="browser">
    <nav class="breadcrumbs">
        @foreach (var breadcrumb in Model.GetBreadcrumbs())
        {
            <a href="@breadcrumb.Url" class="@(breadcrumb.IsMonitored ? "monitored" : null)">
                <em class="icon">@breadcrumb.Icon</em> @breadcrumb.Name
            </a>
        }
    </nav>
    <ul>
        @if (Model.CanGoToParent())
        {
            <li>
                <a href="@Model.GetParentUrl()">
                    <span><em class="icon">⇧</em> .. </span>
                </a>
            </li>
        }
        @foreach (var child in diffEntries)
        {
            <li class="@Model.GetClassName(child.Value)">
                @if (child.Key is Folder folder)
                {
                    <a href="@Model.GetFolderUrl(folder)">
                        <em class="icon">@Model.GetFolderIcon(folder)</em>
                        <span class="folder-name @(Model.IsFolderMonitored(folder) ? "monitored" : null)">
                            @child.Key.Name
                        </span>
                    </a>
                }
                else if (child.Key is File file)
                {
                    <a>
                        <em class="icon">🗎</em>
                        @child.Key.Name
                        @if (file.Version > 1)
                        {
                            <strong>@file.Version </strong>
                        }
                    </a>
                }
            </li>
        }
    </ul>
</div>

@code {
    private IDictionary<FileSystemEntryBase, DiffOperation>? diffEntries;
    
    [SupplyParameterFromQuery]
    public string? Folder { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (Folder == string.Empty)
            NavigationManager.NavigateTo("/browse", replace: true);
        
        Model.LoadFolder(Folder);
        diffEntries = Model.GetDiffEntries();
    }

}
