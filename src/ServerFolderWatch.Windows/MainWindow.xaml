<Window x:Class="ServerFolderWatch.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ServerFolderWatch.Windows"
        xmlns:viewModels="clr-namespace:ServerFolderWatch.Desktop.ViewModels;assembly=ServerFolderWatch.Desktop"
        xmlns:items="clr-namespace:ServerFolderWatch.Desktop.ViewModels.Items;assembly=ServerFolderWatch.Desktop"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:BrowseViewModel}"
        DataContext="{local:Service ServiceType={x:Type viewModels:BrowseViewModel}}"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="160" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="4*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <Border Background="#44000000" Grid.Column="0"
                CornerRadius="8,0,0,8"
                DataContext="{Binding FolderTree}">
            <TreeView ItemsSource="{Binding Folders}"
                      SelectedItemChanged="TreeView_OnSelectedItemChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="{x:Type TreeViewItem}"
                           BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsEnabled" Value="{Binding CanViewContents}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanViewContents}" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate>
                        <Border Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Margin="0,0,16,0"
                                           Foreground="LightSeaGreen"
                                           Text="📁" />
                                <TextBlock Text="{Binding Entry.Name}" />
                            </DockPanel>
                        </Border>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
        
        <GridSplitter Width="8" Grid.Column="1"
                      Background="Transparent"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns" />
        
        <Border Background="#44000000" Grid.Column="2"
                DataContext="{Binding FolderContents}"
                CornerRadius="0,8,8,0">
            
            <ListBox ItemsSource="{Binding Entries}"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" >
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type items:BaseEntryViewModel}">
                        <Grid Width="128"
                              Height="128">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="3*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="📁"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="ExtraLight"
                                       FontSize="64"/>
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       Text="{Binding Entry.Name}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>
