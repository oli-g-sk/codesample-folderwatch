<Window x:Class="ServerFolderWatch.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ServerFolderWatch.Windows"
        xmlns:behaviors="clr-namespace:Olivercode.Dry.UI.Behaviors.WPF;assembly=Olivercode.Dry.UI.Behaviors.WPF"
        xmlns:controls="clr-namespace:Olivercode.WPFastr.Controls;assembly=Olivercode.WPFastr"
        xmlns:viewModels="clr-namespace:ServerFolderWatch.Desktop.ViewModels;assembly=ServerFolderWatch.Desktop"
        xmlns:items="clr-namespace:ServerFolderWatch.Desktop.ViewModels.Items;assembly=ServerFolderWatch.Desktop"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:BrowseViewModel}"
        DataContext="{local:Service ServiceType={x:Type viewModels:BrowseViewModel}}"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="160" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="4*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <Border Background="#44000000" Grid.Column="0"
                CornerRadius="8,0,0,8"
                DataContext="{Binding FolderTree}">
            <TreeView x:Name="FolderTreeView"
                      ItemsSource="{Binding Folders}"
                      SelectedItemChanged="TreeView_OnSelectedItemChanged">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="{x:Type TreeViewItem}"
                           BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsEnabled" Value="{Binding CanViewContents}" />
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanViewContents}" Value="False">
                                <Setter Property="Opacity" Value="{StaticResource DisabledItemOpacity}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <Border Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left"
                                           Margin="0,0,16,0"
                                           Foreground="{StaticResource FolderIconForegroundBrush}"
                                           Text="{Binding Icon}">
                                </TextBlock>
                                <TextBlock Text="{Binding Name}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMonitored}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DockPanel>
                        </Border>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
        
        <GridSplitter Width="8" Grid.Column="1"
                      Background="Transparent"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns" />
        
        <Border Background="#44000000" Grid.Column="2"
                DataContext="{Binding FolderContents}"
                CornerRadius="0,8,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ItemsControl ItemsSource="{Binding Breadcrumbs}" Margin="8,4">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type items:FolderViewModel}">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding Name}"
                                        Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,4">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource {x:Type Button}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMonitored}" Value="True">
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock Text="›" Margin="4,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <controls:BufferedListBox x:Name="FolderContentsListBox"
                                      Grid.Row="1"
                                      ItemsSource="{Binding Entries}"
                                      behaviors:ListBoxDoubleClickBehavior.Command="{Binding OpenEntryCommand}"
                                      Background="Transparent"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" >
                <controls:BufferedListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </controls:BufferedListBox.ItemsPanel>
                <controls:BufferedListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type items:BaseEntryViewModel}">
                        <Grid Width="128"
                              Height="128">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="3*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Icon}"
                                       Opacity="0.75"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="ExtraLight"
                                       FontSize="64">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DiffOperation}" Value="Added">
                                                <Setter Property="Foreground" Value="LimeGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DiffOperation}" Value="Modified">
                                                <Setter Property="Foreground" Value="DarkOrange" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DiffOperation}" Value="Removed">
                                                <Setter Property="Foreground" Value="IndianRed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       Text="{Binding Name}" />
                        </Grid>
                    </DataTemplate>
                </controls:BufferedListBox.ItemTemplate>
                </controls:BufferedListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
